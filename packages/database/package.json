{
  "name": "@dds/database",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed.ts",
    "lint": "echo 'database: no lint config yet'",
    "typecheck": "tsc --noEmit",
    "test": "echo 'database: no tests yet'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dds/shared": "workspace:*",
    "drizzle-orm": "^0.33.0",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/sql.js": "^1.4.9",
    "dotenv": "^16.4.5",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
